  "category": "accessories",
  "display_name": "Accessories",
  "summary": {
    "dos": [
      "Use accessories to anchor, refine, or finish the outfit without competing with its main story.",
      "Match accessory intensity to outfit complexity, occasion, and the number of existing focal points."
    ],
    "donts": [
      "Do not stack too many statement pieces at once.",
      "Do not pair busy accessories with already busy outfits unless the look intentionally calls for maximalism."
    ]
  },
