  "constraints": [
    {
      "mistake_type": "Matchy-Matchy Overload",
      "what_happens": "The bag, jewelry, and other finishing pieces all repeat the exact same color.",
      "why_its_bad": "The look can feel forced and dated instead of coordinated.",
      "engine_constraint": "Limit exact color repetition across finishing pieces."
    },
    {
      "mistake_type": "Too Many Statement Pieces",
      "what_happens": "A bold bag, bold jewelry, and another statement finishing piece all compete at once.",
      "why_its_bad": "The outfit loses hierarchy and feels visually chaotic.",
      "engine_constraint": "Allow only one or two focal finishing pieces."
    },
    {
      "mistake_type": "Over-Accessorizing",
      "what_happens": "Too many accessories are added at once.",
      "why_its_bad": "The outfit feels cluttered and overworked.",
      "engine_constraint": "Cap accessory count and favor balance."
    },
    {
      "mistake_type": "Ignoring Outfit Complexity",
      "what_happens": "Busy accessories are paired with a busy outfit.",
      "why_its_bad": "The accessories compete with the outfit instead of supporting it.",
      "engine_constraint": "Simplify finishing pieces when the core outfit is already complex."
    },
    {
      "mistake_type": "No Contrast",
      "what_happens": "Everything blends into one flat visual field.",
      "why_its_bad": "The styling can feel unfinished or forgettable.",
      "engine_constraint": "Introduce at least one controlled contrast element when the look is too flat."
    },
    {
      "mistake_type": "Wrong Occasion",
      "what_happens": "A casual accessory is used in a formal context, or vice versa.",
      "why_its_bad": "It breaks the coherence of the outfit.",
      "engine_constraint": "Enforce accessory occasion-fit checks."
    }
  ]
