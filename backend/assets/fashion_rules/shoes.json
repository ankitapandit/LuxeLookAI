  "factors": [
    {
      "factor": "Outfit Type Match",
      "logic_derived": "Sneakers lean casual, heels lean dressy, and boots support structured looks."
    },
    {
      "factor": "Occasion Alignment",
      "logic_derived": "Formal settings favor heels, metallics, and black; casual settings favor sneakers and flats."
    },
    {
      "factor": "Color Neutrality",
      "logic_derived": "Neutral shoes maximize compatibility across more outfits."
    },
    {
      "factor": "Contrast Control",
      "logic_derived": "Statement shoes work best when the rest of the outfit is simple."
    },
    {
      "factor": "Seasonal Fit",
      "logic_derived": "Boots skew fall and winter, while sandals skew summer."
    },
    {
      "factor": "Visual Balance",
      "logic_derived": "Nude tones elongate, while bold colors act as focal points."
    },
    {
      "factor": "Style Intent",
      "logic_derived": "Footwear should reinforce whether the outfit is minimal, statement-led, or polished."
    }
