{
  "category": "outerwear",
  "display_name": "Outerwear",
  "summary": {
    "dos": [
      "Use outerwear to shape, polish, soften, or contrast the outfit depending on the occasion and core silhouette.",
      "Match the outer layer's weight, formality, and visual intensity to both the occasion and the base outfit."
    ],
    "donts": [
      "Do not throw a casual topper over a formal look unless the styling intentionally down-dresses it.",
      "Do not let the outer layer overpower the outfit when it should only support or finish it."
    ]
  },
