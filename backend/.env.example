# ─── LuxeLook AI — Backend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Mock mode (default: on) ───────────────────────────────────────────────────
# USE_MOCK_AUTH=true  → No Supabase needed. Auth + DB run fully in memory.
#                       Perfect for local dev. Data resets on server restart.
# USE_MOCK_AUTH=false → Uses real Supabase Auth + DB. Fill in keys below.
USE_MOCK_AUTH=true

# USE_MOCK_AI=true  → No OpenAI/HuggingFace needed. AI calls return mocked data.
# USE_MOCK_AI=false → Uses real CLIP + OpenAI. Fill in OPENAI_API_KEY below.
USE_MOCK_AI=true

# ── JWT (always required — used in both mock and real mode) ───────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Supabase (only needed when USE_MOCK_AUTH=false) ───────────────────────────
# Get these from supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── OpenAI (only needed when USE_MOCK_AI=false) ───────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Discover search provider ────────────────────────────────────────────────
# auto   -> use a configured real provider if available, else mock
# pexels -> Pexels photo search API
# mock   -> deterministic local placeholder results
DISCOVER_SEARCH_PROVIDER=auto
DISCOVER_EMBEDDED_WORKER=true
DISCOVER_WORKER_POLL_SECONDS=3.0

# ── Pexels API (only needed when DISCOVER_SEARCH_PROVIDER=pexels or auto) ──
PEXELS_API_KEY=your-pexels-api-key
